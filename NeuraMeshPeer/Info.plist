<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  NeuraMeshPeer app Info.plist (merged with Xcode's generated keys).
  The two network keys are load-bearing: without BOTH, iOS silently
  blocks Bonjour and the mesh never assembles.
-->
<plist version="1.0">
<dict>
    <key>NSLocalNetworkUsageDescription</key>
    <string>NeuraMesh discovers and connects to nearby devices to run distributed AI inference on your local network.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_neuramesh._tcp</string>
        <string>_neuramesh-ui._tcp</string>
    </array>
    <!-- Future Plan #3: the coordinator's weight-vault is plain HTTP on the LAN
         (trusted-LAN only, like the dashboard). Allow cleartext to .local hosts
         and IP literals so the phone can stream its shard's weights. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
</dict>
</plist>
